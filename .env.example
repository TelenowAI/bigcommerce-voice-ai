# ──────────────────────────────────────────────────────────────────────────
# Telenow BigCommerce App — environment
# Copy to `.env` and fill in. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────────────────

# ── App host ────────────────────────────────────────────────────────────────
# The public HTTPS URL where this app is reachable (no trailing slash).
# In dev, use an ngrok/cloudflared tunnel, e.g. https://abcd-1234.ngrok-free.app
# This builds the OAuth callback URL, the load/uninstall URLs, the BigCommerce
# webhook destination, and the Telenow webhook target URL.
HOST=https://your-tunnel.ngrok-free.app
PORT=3000

# ── BigCommerce app credentials ──────────────────────────────────────────────
# From your app in the BigCommerce Developer Portal (My Apps → your app → View
# Client ID). The "Auth Callback URL" there must be <HOST>/auth, the "Load
# Callback URL" <HOST>/load, "Uninstall" <HOST>/uninstall, "Remove User"
# <HOST>/remove-user.
BIGCOMMERCE_CLIENT_ID=
BIGCOMMERCE_CLIENT_SECRET=

# The OAuth redirect_uri sent to BigCommerce's token endpoint. Must EXACTLY match
# the "Auth Callback URL" configured on the app. Defaults to <HOST>/auth.
# BIGCOMMERCE_AUTH_CALLBACK=https://your-tunnel.ngrok-free.app/auth

# BigCommerce login/token host (rarely changed).
# BIGCOMMERCE_LOGIN_URL=https://login.bigcommerce.com
# BigCommerce REST API host (rarely changed).
# BIGCOMMERCE_API_URL=https://api.bigcommerce.com

# ── Telenow API ──────────────────────────────────────────────────────────────
# Base URL of the Telenow public API. Default works for production.
TELENOW_API_BASE=https://api.telenow.ai

# NOTE: the Telenow API key is NOT set here. Each merchant pastes their own
# `vai_live_...` key in the in-app settings page (/app). It is stored per-store.

# ── Persistence (stub) ────────────────────────────────────────────────────────
# Directory where the file-based store keeps store sessions, settings, the
# sessionId→entity map, hooks, dedupe attempts and leads. Swap the whole store
# for a real DB in production.
DATA_DIR=./data

# ── Phone normalization ───────────────────────────────────────────────────────
# ISO-2 country assumed for local numbers that have no country code (default IN).
DEFAULT_PHONE_COUNTRY=IN

# ── Scheduler (win-back sweep) ────────────────────────────────────────────────
# Cadence of the background sweeps (default 6h) and an opt-in to run once at boot.
# SWEEP_INTERVAL_MS=21600000
# SWEEP_RUN_ON_BOOT=1
